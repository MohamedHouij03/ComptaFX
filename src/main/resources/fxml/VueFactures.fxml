<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.comptafx.presentation.ControleurFactures"
      spacing="15" styleClass="page-content">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    
    <Label text="Gestion des Factures" styleClass="page-title"/>
    
    <!-- Barre d'outils -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Nouvelle Facture" onAction="#handleNewInvoice" styleClass="primary-btn"/>
        <Button text="Modifier" onAction="#handleEditInvoice" styleClass="secondary-btn"/>
        <Button text="Supprimer" onAction="#handleDeleteInvoice" styleClass="danger-btn"/>
        <Separator orientation="VERTICAL"/>
        <TextField fx:id="searchField" promptText="Rechercher..." prefWidth="200"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>
    
    <!-- Tableau des factures -->
    <TableView fx:id="invoicesTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="invoiceNumberColumn" text="N° Facture" prefWidth="120"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="100"/>
            <TableColumn fx:id="customerColumn" text="Client/Fournisseur" prefWidth="180"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="100"/>
            <TableColumn fx:id="dueDateColumn" text="Échéance" prefWidth="100"/>
            <TableColumn fx:id="totalColumn" text="Total" prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="Statut" prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="Aucune facture trouvée."/>
        </placeholder>
    </TableView>
    
    <!-- Barre de statut -->
    <HBox styleClass="page-status-bar">
        <Label fx:id="statusLabel" text="Prêt"/>
    </HBox>
</VBox>
